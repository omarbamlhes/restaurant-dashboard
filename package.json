{
  "name": "restaurant-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Smart Restaurant Analytics Dashboard — لوحة المطاعم الذكية",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:api": "pnpm --filter @app/api run start:dev",
    "dev:web": "pnpm --filter @app/web run dev",
    "build": "pnpm -r run build",
    "db:migrate": "pnpm --filter @app/api run prisma:migrate",
    "db:seed": "pnpm --filter @app/api run prisma:seed",
    "db:studio": "pnpm --filter @app/api run prisma:studio"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
